{
  "name": "tote",
  "displayName": "Tote",
  "description": "Keeps temporary notes and todo list while developing to improve DX",
  "publisher": "kito-arch",
  "version": "0.0.3",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "assets/icon.png",
  "repository": {
    "url": "https://github.com/kito-arch/tote"
  },
  "homepage": "https://marketplace.visualstudio.com/items?itemName=kito-arch.tote",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tote.open",
        "title": "Tote: Open"
      }
    ]
  },
  "keywords": [
    "notes",
    "todo",
    "DX",
    "extension",
    "developer tools",
    "productivity",
    "lightweight"
  ],
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.115.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
